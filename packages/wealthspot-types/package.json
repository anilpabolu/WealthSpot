{
  "name": "@wealthspot/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for WealthSpot platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  },
  "files": [
    "dist",
    "src"
  ]
}
