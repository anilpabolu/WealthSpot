{
  "name": "@wealthspot/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Shared API client (axios + token refresh + snake-camel transform) for WealthSpot web & mobile",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "axios": "^1.7.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  },
  "files": [
    "dist",
    "src"
  ]
}
