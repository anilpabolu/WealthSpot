# ── WealthSpot Mobile App Environment ──────────────────
# Copy this file to .env and fill in the values.

# Backend API base URL (must include /api/v1 suffix)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# Clerk authentication (publishable key from https://dashboard.clerk.com)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Sentry DSN for crash reporting (optional)
EXPO_PUBLIC_SENTRY_DSN=
