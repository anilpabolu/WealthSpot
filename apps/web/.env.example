# ─── WealthSpot Web – Environment Variables ──────────────
# Copy to .env.local and fill in the values.

# ─── API ──────────────────────────────────────────────────
# Backend API base URL (set to your production domain for deployment)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── Clerk Auth ───────────────────────────────────────────
# Get your key from https://dashboard.clerk.com/~/api-keys (choose React)
VITE_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# ─── Sentry (Error Monitoring) ────────────────────────────
# Get DSN from https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=

# ─── Razorpay (Payments) ─────────────────────────────────
VITE_RAZORPAY_KEY_ID=

# ─── Optional ─────────────────────────────────────────────
VITE_MAPBOX_TOKEN=
VITE_POSTHOG_KEY=
VITE_ENABLE_DIAGNOSTICS=false
