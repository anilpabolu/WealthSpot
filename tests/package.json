{
  "name": "@wealthspot/tests",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test:web": "vitest run -c web/vitest.config.ts",
    "test:web:functional": "vitest run -c web/vitest.functional.config.ts",
    "test:web:coverage": "vitest run -c web/vitest.config.ts --coverage",
    "test:web:e2e": "playwright test -c web/playwright.config.ts",
    "test:mobile": "vitest run -c mobile/vitest.config.ts",
    "test:mobile:functional": "vitest run -c mobile/vitest.functional.config.ts",
    "test:mobile:coverage": "vitest run -c mobile/vitest.config.ts --coverage",
    "test:api": "cd api && pytest",
    "test:api:coverage": "cd api && pytest --cov=app --cov-report=term-missing",
    "test:all": "npm run test:web && npm run test:mobile && npm run test:api",
    "test": "npm run test:all"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^29.0.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@clerk/react": "^6.1.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-query": "^5.94.0",
    "@wealthspot/types": "*",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "decimal.js": "^10.4.3",
    "lucide-react": "^0.394.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.0",
    "zustand": "^4.5.7"
  }
}
