# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/wealthspot
DATABASE_ECHO=false

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Clerk (optional – for webhook verification) ─────────
CLERK_WEBHOOK_SECRET=
CLERK_API_KEY=

# ─── Redis / Celery ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ─── AWS S3 / MinIO (Object storage) ─────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=wealthspot-media
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/wealthspot-media

# ─── Razorpay ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Sentry ───────────────────────────────────────────────
SENTRY_DSN=

# ─── App ──────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
