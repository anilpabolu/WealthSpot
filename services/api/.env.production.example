# ─── WealthSpot API – Production Environment ─────────────
# Copy to .env and fill ALL values before deploying to production.
# NEVER commit this file with real credentials.

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wealthspot:STRONG_PASSWORD@db-host:5432/wealthspot
DATABASE_ECHO=false

# ─── Auth ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Clerk ────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_XXXXXX
CLERK_API_KEY=sk_live_XXXXXX

# ─── Redis / Celery ──────────────────────────────────────
REDIS_URL=redis://redis-host:6379/0
CELERY_BROKER_URL=redis://redis-host:6379/1

# ─── AWS S3 (Media Storage) ──────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXX
AWS_S3_BUCKET=wealthspot-media-prod
AWS_REGION=ap-south-1
S3_ENDPOINT_URL=
S3_PUBLIC_URL=https://wealthspot-media-prod.s3.ap-south-1.amazonaws.com

# ─── Razorpay (Payments) ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXX
RAZORPAY_KEY_SECRET=XXXXXX

# ─── Sentry (Error Monitoring) ───────────────────────────
# Get DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=https://XXXXXX@o123456.ingest.sentry.io/654321

# ─── SMTP (Transactional Email) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-app@gmail.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM_EMAIL=no-reply@wealthspot.in
SMTP_FROM_NAME=WealthSpot

# ─── Twilio (SMS / WhatsApp) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXX
TWILIO_AUTH_TOKEN=XXXXXX
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Encryption (Fernet) ─────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=XXXXXX

# ─── App ──────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
# ⚠️ Set to your actual production domains. Comma-separated, no trailing slash.
CORS_ORIGINS=https://app.wealthspot.in,https://wealthspot.in
